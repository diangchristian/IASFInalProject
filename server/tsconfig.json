{
  // Visit https://aka.ms/tsconfig to read more about this file
  "ts-node": {
    "files": true
  },
  "compilerOptions": {
   
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "nodenext",
    "target": "es2016",
    "esModuleInterop": true,
    "types": [],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "skipLibCheck": true,
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/database/mongodb.ts"],
  "exclude": ["node_modules"]
}
